PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

DATABASE_URL="mysql://root:@localhost:3306/support_tickets"

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=support_tickets

# node-cron schedule — default every minute
CRON_SCHEDULE=* * * * *

# SLA windows in hours
SLA_URGENT_HOURS=2
SLA_HIGH_HOURS=8
SLA_MEDIUM_HOURS=24
SLA_LOW_HOURS=72

# Warning threshold: fraction of SLA window (0.20 = final 20%)
SLA_WARNING_THRESHOLD=0.20

LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
